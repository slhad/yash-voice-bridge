{
  "name": "yash-voice-bridge",
  "version": "0.1.0",
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "^1.3.2",
    "typescript": "^5.9.3"
  },
  "private": true,
  "scripts": {
    "appimage": "./scripts/build-appimage.sh",
    "build": "bun build --compile --target=bun-linux-x64 src/index.ts --outfile dist/yash-voice-bridge",
    "config:show": "bun run src/config.ts",
    "dev": "bun --watch src/index.ts --mode raw",
    "models": "bun run src/models.ts",
    "models:download": "bun run src/models.ts download",
    "models:installed": "bun run src/models.ts installed",
    "models:list": "bun run src/models.ts list",
    "raw": "bun run src/index.ts --mode raw",
    "sources:list": "bun run src/index.ts --list-sources",
    "start": "bun run src/index.ts --mode raw",
    "typecheck": "bunx tsc --noEmit",
    "lint": "biome lint src/",
    "format": "biome format --write src/",
    "check": "biome check --write src/"
  },
  "type": "module"
}
